{
  "name": "tx-analyzer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/tx-analyzer/src",
  "tags": ["type:app", "scope:backend", "lang:typescript"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/tx-analyzer",
        "command": "tsx watch --clear-screen=false src/main.ts"
      },
      "configurations": {
        "development": {
          "command": "tsx watch --clear-screen=false src/main.ts"
        },
        "production": {
          "command": "node dist/main.js"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/tx-analyzer"],
      "options": {
        "command": "tsc --project tsconfig.app.json",
        "cwd": "apps/tx-analyzer"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project tsconfig.app.json",
        "cwd": "apps/tx-analyzer"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/tx-analyzer/**/*.ts"]
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"apps/tx-analyzer/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config jest.config.ts",
        "cwd": "apps/tx-analyzer"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rm -rf dist/apps/tx-analyzer",
          "rm -rf apps/tx-analyzer/node_modules",
          "rm -rf apps/tx-analyzer/.nx"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false
      }
    }
  }
}
