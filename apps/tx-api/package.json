{
  "name": "@msq-tx-monitor/tx-api",
  "version": "1.0.0",
  "description": "NestJS GraphQL API server for MSQ transaction monitoring",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--loader ts-node/esm' ts-node --project tsconfig.app.json -r tsconfig-paths/register --esm --experimental-specifier-resolution=node src/main.ts",
    "build": "rm -rf dist && tsc --project tsconfig.app.json",
    "start": "NODE_OPTIONS='--loader ts-node/esm' ts-node --project tsconfig.app.json -r tsconfig-paths/register --esm --experimental-specifier-resolution=node src/main.ts",
    "test": "jest --config jest.config.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit --project tsconfig.app.json",
    "clean": "rm -rf dist node_modules .nx",
    "depcheck": "depcheck"
  },
  "dependencies": {
    "@apollo/server": "^4.11.2",
    "@as-integrations/express5": "^1.0.0",
    "@msq-tx-monitor/subgraph-client": "workspace:*",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/websockets": "^11.1.8",
    "cache-manager": "^7.2.4",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "graphql": "^16.12.0",
    "graphql-query-complexity": "^1.1.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.9",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.0",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "nestjs",
    "graphql",
    "api",
    "websocket",
    "blockchain",
    "transaction",
    "monitoring",
    "msq"
  ]
}
