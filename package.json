{
  "name": "msq-tx-monitor",
  "version": "1.0.0",
  "description": "Real-time Blockchain Transaction Monitoring System for MSQ Wallet Tokens",
  "keywords": [
    "blockchain",
    "transaction-monitoring",
    "polygon",
    "msq",
    "real-time",
    "web3",
    "nx-monorepo"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nx run-many --target=serve --projects=tx-api,chain-scanner,tx-analyzer --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "nx format:check --libs-and-apps",
    "format:fix": "nx format:write --libs-and-apps",
    "typecheck": "nx run-many --target=typecheck --all",
    "depcheck": "nx run-many --target=depcheck --all",
    "clean": "nx reset && rm -rf node_modules && rm -rf dist",
    "api": "pnpm --filter @msq-tx-monitor/tx-api",
    "scanner": "pnpm --filter @msq-tx-monitor/chain-scanner",
    "analyzer": "pnpm --filter @msq-tx-monitor/tx-analyzer",
    "docker:dev": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "docker:prod": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.dev.yml down && docker-compose -f docker/docker-compose.yml down",
    "apps:dev": "pnpm --filter './apps/*' dev",
    "apps:build": "pnpm --filter './apps/*' build",
    "apps:test": "pnpm --filter './apps/*' test",
    "apps:lint": "pnpm --filter './apps/*' lint"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "21.5.2",
    "@nx/eslint-plugin": "21.5.2",
    "@nx/jest": "21.5.2",
    "@nx/js": "22.0.2",
    "@nx/nest": "22.0.2",
    "@nx/node": "22.0.2",
    "@nx/react": "21.5.2",
    "@nx/vite": "21.5.2",
    "@nx/web": "22.0.2",
    "@nx/webpack": "22.0.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.3.1",
    "depcheck": "^1.4.7",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^30.0.2",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "21.5.2",
    "prettier": "3.2.5",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "5.4.5",
    "vite": "^7.0.0",
    "vitest": "^1.3.1",
    "webpack-cli": "^5.1.4"
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "cache-manager": "^7.2.4",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}
